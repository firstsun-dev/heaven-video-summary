# config.env — YouTube Dharma Talk Pipeline Configuration

# YouTube playlist URL (required)
PLAYLIST_URL="https://m.youtube.com/playlist?list=PLefw8Oiz6WU-s263yJOCb_dFznzQ2CBV4"

# Whisper settings (mlx-whisper models: tiny, base, small, medium, large, large-v3-turbo)
WHISPER_MODEL="mlx-community/whisper-large-v3-turbo"
WHISPER_LANGUAGE="Chinese"

# Archive directory name
ARCHIVE_DIR="youtube-dharma-talk"

# Rclone remote and target path
# Note: For GitHub Actions, use GDRIVE_FOLDER_ID: 1otgdW74CgqyBdQ2amniGeCUOToSIDpte
RCLONE_REMOTE="gdrive:buddhist-lectures"

# Temporary working directory
TEMP_DIR="temp"
