# config.env — YouTube Dharma Talk Pipeline Configuration

# YouTube playlist URL (required)
PLAYLIST_URL="https://www.youtube.com/watch?v=kndPNlWS73I&list=PLefw8Oiz6WU-s263yJOCb_dFznzQ2CBV4"

# Whisper settings (mlx-whisper models: tiny, base, small, medium, large)
# WHISPER_MODEL="mlx-community/Whisper-large-v3-mlx"
WHISPER_MODEL="mlx-community/whisper-large-v3-turbo"
WHISPER_LANGUAGE="Chinese"

# Archive directory name
ARCHIVE_DIR="youtube-dharma-talk"

# Rclone remote and target path (required)
RCLONE_REMOTE="dmc_gdrive:heavenfortress-youtube-info"

# Temporary working directory
TEMP_DIR="temp"
