# config.env — YouTube Dharma Talk Pipeline Configuration

# YouTube playlist URL (required)
PLAYLIST_URL=""

# Whisper settings
WHISPER_MODEL="large-v3"
WHISPER_LANGUAGE="Chinese"

# Archive directory name
ARCHIVE_DIR="youtube-dharma-talk"

# Rclone remote and target path (required)
RCLONE_REMOTE=""

# Temporary working directory
TEMP_DIR="temp"
